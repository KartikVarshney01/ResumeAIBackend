{
  "Jwt": {
    "Secret": "ThisIsAVeryLongSecretKeyForResumeAIPlatform2026!",
    "Issuer": "ResumeAI.Auth",
    "Audience": "ResumeAI.Clients"
  },
  "IpRateLimiting": {
    "EnableEndpointRateLimiting": true,
    "StackBlockedRequests": false,
    "RealIpHeader": "X-Real-IP",
    "ClientIdHeader": "X-ClientId",
    "HttpStatusCode": 429,
    "GeneralRules": [
      {
        "Endpoint": "*",
        "Period": "1m",
        "Limit": 60
      },
      {
        "Endpoint": "*/api/auth/login",
        "Period": "1m",
        "Limit": 10
      },
      {
        "Endpoint": "*/api/ai/*",
        "Period": "1m",
        "Limit": 60
      }
    ]
  },
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" }
      },
      "resume-route": {
        "ClusterId": "resume-cluster",
        "Match": { "Path": "/api/resumes/{**catch-all}" }
      },
      "section-route": {
        "ClusterId": "resume-cluster",
        "Match": { "Path": "/api/sections/{**catch-all}" }
      },
      "ai-route": {
        "ClusterId": "ai-cluster",
        "Match": { "Path": "/api/ai/{**catch-all}" }
      },
      "template-route": {
        "ClusterId": "template-cluster",
        "Match": { "Path": "/api/templates/{**catch-all}" }
      },
      "export-route": {
        "ClusterId": "export-cluster",
        "Match": { "Path": "/api/exports/{**catch-all}" }
      },
      "jobmatch-route": {
        "ClusterId": "jobmatch-cluster",
        "Match": { "Path": "/api/jobmatches/{**catch-all}" }
      },
      "notification-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/api/notifications/{**catch-all}" }
      },
      "payment-route": {
        "ClusterId": "payment-cluster",
        "Match": { "Path": "/api/payments/{**catch-all}" }
      },
      "signalr-route": {
        "ClusterId": "notification-cluster",
        "Match": { "Path": "/hubs/{**catch-all}" }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth": { "Address": "http://localhost:5008/" }
        }
      },
      "resume-cluster": {
        "Destinations": {
          "resume": { "Address": "http://localhost:5135/" }
        }
      },
      "ai-cluster": {
        "Destinations": {
          "ai": { "Address": "http://localhost:5121/" }
        }
      },
      "template-cluster": {
        "Destinations": {
          "template": { "Address": "http://localhost:5175/" }
        }
      },
      "export-cluster": {
        "Destinations": {
          "export": { "Address": "http://localhost:5165/" }
        }
      },
      "jobmatch-cluster": {
        "Destinations": {
          "jobmatch": { "Address": "http://localhost:5144/" }
        }
      },
      "notification-cluster": {
        "Destinations": {
          "notification": { "Address": "http://localhost:5212/" }
        }
      },
      "payment-cluster": {
        "Destinations": {
          "payment": { "Address": "http://localhost:5003/" }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}